# Science Radar Podcast — Environment Variables
# Copy to .env and fill in your values (never commit .env to git)

# ── Required ──────────────────────────────────────────────────────────────────

# Free OpenRouter API key (no credit card needed): https://openrouter.ai
# Gives access to Gemini 2.0 Flash, Llama 3, Mistral, etc. for free
OPENROUTER_API_KEY=sk-or-v1-...

# GitHub Personal Access Token (for committing state + creating releases)
# Scopes needed: repo, workflow
GH_PAT=ghp_...

# ── Optional ──────────────────────────────────────────────────────────────────

# Override episode date (YYYY-MM-DD). Default: today.
# RUN_DATE=2026-03-08

# Force regenerate even if episode already published
# FORCE_REGEN=false

# Regenerate only the script (reuse cached LLM analyses)
# REGEN_SCRIPT=false

# GitHub repo for release URLs in the site (format: username/repo-name)
# GITHUB_REPO=yourusername/science-radar-podcast

# Podcast title shown on the site
# PODCAST_TITLE=Science Radar

# Audio playback speed via ffmpeg atempo (1.0 = normal, 1.2 = 20% faster)
# PODCAST_ATEMPO=1.0
